#!/usr/bin/env python3

import sys
from pathlib import Path


def main():
    start_dir = Path(sys.argv[1]) if len(sys.argv) > 1 else Path.cwd()

    if not start_dir.exists():
        print(f"Error: The path '{start_dir}' does not exist.")
        sys.exit(1)

    max_length = 0
    longest_path = ""

    def get_all_paths(base):
        yield base
        yield from base.rglob("*")

    for path_obj in get_all_paths(start_dir):
        path_str = str(path_obj)
        path_length = len(path_str)

        if path_length > 180:
            print(path_str)

        if path_length > max_length:
            max_length = path_length
            longest_path = path_str

    print("\n--- Longest Path Overall ---")
    if longest_path:
        print(f"{max_length}: {longest_path}")
    else:
        print("0: No paths found.")


if __name__ == "__main__":
    main()
