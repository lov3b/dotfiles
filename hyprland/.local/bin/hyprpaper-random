#!/usr/bin/env python3
import os
import random
import subprocess
from pathlib import Path


def is_image(path: Path) -> bool:
    return path.suffix.lower() in {".jpg", ".jpeg", ".png", ".webp"}


def main() -> int:
    wallpapers_dir = Path.home() / "Pictures" / "wallpapers"
    dynamic_path = wallpapers_dir / "dynamic"

    if not wallpapers_dir.is_dir():
        return 0

    try:
        dynamic_samefile = dynamic_path.exists()
    except OSError:
        dynamic_samefile = False

    candidates = []
    for root, _dirs, files in os.walk(wallpapers_dir, followlinks=False):
        for name in files:
            path = Path(root) / name
            if not is_image(path):
                continue
            if path == dynamic_path:
                continue
            if dynamic_samefile:
                try:
                    if os.path.samefile(path, dynamic_path):
                        continue
                except OSError:
                    pass
            candidates.append(path)

    if not candidates:
        return 0

    choice = random.choice(candidates)

    try:
        if dynamic_path.exists() or dynamic_path.is_symlink():
            dynamic_path.unlink()
    except OSError:
        return 0

    try:
        dynamic_path.symlink_to(choice)
    except OSError:
        return 0

    subprocess.run(["pkill", "hyprpaper"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.Popen(["hyprpaper"])
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
