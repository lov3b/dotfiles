#!/usr/bin/env sh
set -eu

if [ $# -eq 0 ]; then
    printf "Usage: %s <cmd> [args] -- <cmd> [args] ...\n" "${0##*/}" >&2
    exit 2
fi

try_exec() {
    if command -v "$1" >/dev/null 2>&1; then
        exec "$@"
    fi
}

current=()
while [ $# -gt 0 ]; do
    if [ "$1" = "--" ]; then
        if [ ${#current[@]} -gt 0 ]; then
            try_exec "${current[@]}"
            current=()
        fi
        shift
        continue
    fi
    current+=("$1")
    shift
done

if [ ${#current[@]} -gt 0 ]; then
    try_exec "${current[@]}"
fi

printf "No command available\n" >&2
exit 1
